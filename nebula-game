<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>NEBULA EXCHANGE — создай свой токен</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='%230a0c10'/%3E%3Ccircle cx='50' cy='50' r='45' fill='none' stroke='%2300ffaa' stroke-width='0.5' stroke-dasharray='2 3'/%3E%3Cpath d='M50 5 Q70 30 50 50 Q30 70 50 95' stroke='%2300ffaa' stroke-width='1' fill='none' opacity='0.8'/%3E%3Ccircle cx='50' cy='50' r='3' fill='%2300ffaa'/%3E%3Ccircle cx='28' cy='28' r='1' fill='white'/%3E%3Ccircle cx='72' cy='32' r='1.2' fill='white'/%3E%3C/svg%3E">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Courier New', monospace;
            background: #0a0c10;
            min-height: 100vh;
            overflow-x: hidden;
        }
        .starfield {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            overflow: hidden;
            background: radial-gradient(ellipse at center, #0a0c10 0%, #000000 100%);
        }
        .star {
            position: absolute;
            background-color: white;
            border-radius: 50%;
            animation: twinkle linear infinite;
        }
        @keyframes twinkle {
            0% { opacity: 0.2; transform: scale(1); }
            50% { opacity: 1; transform: scale(1.2); }
            100% { opacity: 0.2; transform: scale(1); }
        }
        .floating-galaxy {
            position: fixed;
            bottom: -150px;
            right: -150px;
            width: 500px;
            height: 500px;
            opacity: 0.12;
            pointer-events: none;
            z-index: 0;
            animation: floatGalaxy 40s linear infinite;
        }
        @keyframes floatGalaxy {
            0% { transform: translate(0, 0) rotate(0deg); }
            100% { transform: translate(-80px, -80px) rotate(360deg); }
        }
        .main-container {
            position: relative;
            z-index: 1;
            min-height: 100vh;
        }
        /* СТРАНИЦА ВХОДА */
        .login-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(10, 12, 16, 0.96);
            backdrop-filter: blur(8px);
            z-index: 1000;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: opacity 0.5s ease;
        }
        .login-screen.hidden {
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
        }
        .login-card {
            text-align: center;
            padding: 40px;
            background: rgba(17, 21, 30, 0.95);
            border: 2px solid #00ffaa;
            border-radius: 32px;
            box-shadow: 0 0 60px rgba(0, 255, 170, 0.3);
            max-width: 400px;
            width: 90%;
            animation: glowPulse 2s ease-in-out infinite;
        }
        @keyframes glowPulse {
            0% { box-shadow: 0 0 20px rgba(0, 255, 170, 0.2); border-color: #00ffaa; }
            50% { box-shadow: 0 0 50px rgba(0, 255, 170, 0.5); border-color: #88ffcc; }
            100% { box-shadow: 0 0 20px rgba(0, 255, 170, 0.2); border-color: #00ffaa; }
        }
        .galaxy-logo {
            width: 120px;
            height: 120px;
            margin: 0 auto 20px;
        }
        .galaxy-logo svg {
            width: 100%;
            height: 100%;
            filter: drop-shadow(0 0 10px #00ffaa);
        }
        .login-card h1 {
            color: #00ffaa;
            font-size: 32px;
            letter-spacing: 4px;
            margin-bottom: 8px;
            text-shadow: 0 0 10px #00ffaa;
        }
        .login-card .subtitle {
            color: #88ffcc;
            font-size: 14px;
            margin-bottom: 30px;
        }
        .login-card input {
            width: 100%;
            padding: 14px;
            background: #000000cc;
            border: 1px solid #00ffaa;
            color: #00ffaa;
            font-size: 16px;
            font-family: monospace;
            border-radius: 12px;
            margin-bottom: 20px;
            text-align: center;
        }
        .login-card input:focus {
            outline: none;
            box-shadow: 0 0 15px #00ffaa;
        }
        .login-card button {
            width: 100%;
            padding: 14px;
            background: #00ffaa20;
            border: 1px solid #00ffaa;
            color: #00ffaa;
            font-size: 18px;
            font-weight: bold;
            font-family: monospace;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .login-card button:hover {
            background: #00ffaa;
            color: #000;
            box-shadow: 0 0 20px #00ffaa;
        }
        .make-token-text {
            margin-top: 24px;
            font-size: 12px;
            color: #00ffaa88;
            letter-spacing: 2px;
        }
        /* ИНТЕРФЕЙС БИРЖИ */
        .exchange-interface {
            display: none;
            position: relative;
            z-index: 2;
            padding: 20px;
        }
        .exchange-interface.active {
            display: block;
        }
        .terminal-header {
            background: #000000aa;
            padding: 10px 16px;
            border-bottom: 2px solid #00ffaa;
            margin-bottom: 24px;
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            font-weight: bold;
            backdrop-filter: blur(4px);
        }
        .dashboard {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 24px;
        }
        .wallet-panel, .token-panel, .trade-panel {
            background: #11151ecc;
            backdrop-filter: blur(8px);
            border: 1px solid #2a3a4a;
            border-radius: 12px;
            padding: 18px;
        }
        h2, h3 {
            margin-top: 0;
            border-left: 4px solid #00ffaa;
            padding-left: 10px;
        }
        button {
            background: #1e2a36;
            color: #00ffaa;
            border: 1px solid #00ffaa;
            padding: 8px 14px;
            margin: 6px 4px;
            cursor: pointer;
            font-family: monospace;
            font-weight: bold;
            border-radius: 6px;
        }
        button:active {
            background: #00ffaa;
            color: #000;
        }
        input, select {
            background: #000000cc;
            color: #00ffaa;
            border: 1px solid #2a6b6b;
            padding: 8px;
            margin: 6px 0;
            width: 100%;
            font-family: monospace;
            border-radius: 6px;
        }
        ul {
            list-style: none;
            padding: 0;
            max-height: 200px;
            overflow-y: auto;
        }
        li {
            border-bottom: 1px solid #2a3a4a;
            padding: 6px 4px;
        }
        .order-book-entry {
            display: flex;
            justify-content: space-between;
            border-bottom: 1px solid #2a6b6b;
            padding: 6px 4px;
        }
        .buy { color: #00cc88; }
        .sell { color: #ff6680; }
        .order-book-header {
            background: #1a2a2a;
            padding: 6px;
            margin-top: 8px;
            font-weight: bold;
            text-align: center;
        }
        hr { border-color: #2a6b6b; margin: 16px 0; }
        .token-badge {
            background: #1e3a3a;
            display: inline-block;
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 0.75rem;
            margin-left: 6px;
        }
        footer {
            margin-top: 40px;
            text-align: center;
            font-size: 0.7rem;
            opacity: 0.7;
            border-top: 1px solid #2a3a4a;
            padding-top: 16px;
        }
        ::-webkit-scrollbar { width: 6px; background: #111; }
        ::-webkit-scrollbar-thumb { background: #00ffaa; border-radius: 4px; }
    </style>
</head>
<body>

<div class="starfield" id="starfield"></div>
<div class="floating-galaxy">
    <svg width="500" height="500" viewBox="0 0 100 100">
        <rect width="100" height="100" fill="none"/>
        <circle cx="50" cy="50" r="45" fill="none" stroke="#00ffaa" stroke-width="0.3" stroke-dasharray="1 3"/>
        <path d="M50 5 Q70 30 50 50 Q30 70 50 95" stroke="#00ffaa" stroke-width="0.5" fill="none" opacity="0.6"/>
        <circle cx="50" cy="50" r="2" fill="#00ffaa" opacity="0.5"/>
    </svg>
</div>

<div class="main-container">
    <div class="login-screen" id="loginScreen">
        <div class="login-card">
            <div class="galaxy-logo">
                <svg viewBox="0 0 100 100">
                    <rect width="100" height="100" fill="#0a0c10" rx="20"/>
                    <g>
                        <animateTransform attributeName="transform" type="rotate" from="0 50 50" to="360 50 50" dur="15s" repeatCount="indefinite"/>
                        <path d="M50 8 Q72 28 50 50 Q28 72 50 92" stroke="#00ffaa" stroke-width="1.2" fill="none" opacity="0.9"/>
                        <path d="M50 8 Q28 28 50 50 Q72 72 50 92" stroke="#88ffcc" stroke-width="0.8" fill="none" opacity="0.7"/>
                    </g>
                    <circle cx="50" cy="50" r="5" fill="#00ffaa">
                        <animate attributeName="r" values="3;6;3" dur="1.5s" repeatCount="indefinite"/>
                        <animate attributeName="opacity" values="1;0.5;1" dur="1.5s" repeatCount="indefinite"/>
                    </circle>
                    <circle cx="25" cy="20" r="1.2" fill="white"><animate attributeName="opacity" values="0.3;1;0.3" dur="1.2s" repeatCount="indefinite"/></circle>
                    <circle cx="75" cy="25" r="1" fill="white"><animate attributeName="opacity" values="0.5;1;0.5" dur="1.8s" repeatCount="indefinite"/></circle>
                    <circle cx="30" cy="75" r="0.9" fill="white"><animate attributeName="opacity" values="0.4;0.9;0.4" dur="2s" repeatCount="indefinite"/></circle>
                    <circle cx="70" cy="72" r="1.1" fill="white"><animate attributeName="opacity" values="0.6;1;0.6" dur="2.3s" repeatCount="indefinite"/></circle>
                    <circle cx="18" cy="50" r="0.8" fill="white"><animate attributeName="opacity" values="0.2;0.8;0.2" dur="1.5s" repeatCount="indefinite"/></circle>
                    <circle cx="82" cy="48" r="0.7" fill="white"><animate attributeName="opacity" values="0.7;1;0.7" dur="1.7s" repeatCount="indefinite"/></circle>
                </svg>
            </div>
            <h1>NEBULA EXCHANGE</h1>
            <div class="subtitle">✦ создай свой токен ✦</div>
            <input type="text" id="loginUsername" placeholder="Введите имя космонавта" maxlength="20">
            <button id="enterBtn">🚀 ВОЙТИ В ГАЛАКТИКУ 🚀</button>
            <div class="make-token-text">⚡ КАЖДЫЙ МОЖЕТ СОЗДАТЬ ТОКЕН ⚡</div>
        </div>
    </div>

    <div class="exchange-interface" id="exchangeInterface">
        <div class="terminal-header">
            <div style="display: flex; align-items: center; gap: 12px;">
                <div style="width: 32px; height: 32px;">
                    <svg width="32" height="32" viewBox="0 0 100 100">
                        <rect width="100" height="100" fill="#0a0c10" rx="8"/>
                        <g><animateTransform attributeName="transform" type="rotate" from="0 50 50" to="360 50 50" dur="15s" repeatCount="indefinite"/>
                        <path d="M50 8 Q72 28 50 50 Q28 72 50 92" stroke="#00ffaa" stroke-width="0.8" fill="none"/></g>
                        <circle cx="50" cy="50" r="3" fill="#00ffaa"><animate attributeName="r" values="2;4;2" dur="1.5s" repeatCount="indefinite"/></circle>
                    </svg>
                </div>
                <span>✦ NEBULA EXCHANGE [FAKE MODE] ✦</span>
            </div>
            <span id="systemTime"></span>
        </div>
        <div class="dashboard">
            <div class="wallet-panel">
                <h2>💼 КОШЕЛЕК</h2>
                <div><h3>💰 Балансы</h3><ul id="balanceList"></ul></div>
                <hr><h3>🔄 Перевод</h3>
                <input type="text" id="transferTo" placeholder="Кому (логин)">
                <input type="text" id="transferSymbol" placeholder="Актив (USDT или TOKEN_XYZ)">
                <input type="number" id="transferAmount" placeholder="Сумма" step="any">
                <button id="transferBtn">ОТПРАВИТЬ</button>
            </div>
            <div class="token-panel">
                <h2>⚡ СОЗДАТЬ ТОКЕН</h2>
                <input type="text" id="tokenName" placeholder="Название: МемCoin">
                <input type="text" id="tokenSymbol" placeholder="Символ (3-5 букв)">
                <input type="number" id="tokenSupply" placeholder="Эмиссия" step="1">
                <button id="createTokenBtn">🚀 СОЗДАТЬ ТОКЕН</button>
                <hr><h3>📜 Список токенов</h3>
                <div id="tokenList" style="max-height: 240px; overflow-y: auto;"></div>
            </div>
            <div class="trade-panel">
                <h2>📊 ТОРГОВЛЯ</h2>
                <select id="tradeSymbolSelect"></select>
                <div style="background:#0a0e14;padding:10px;border-radius:8px;margin:12px 0;">
                    <h3>📌 Ордер</h3>
                    <select id="orderType"><option value="buy">🟢 ПОКУПКА</option><option value="sell">🔴 ПРОДАЖА</option></select>
                    <input type="number" id="orderPrice" placeholder="Цена в USDT" step="any">
                    <input type="number" id="orderAmount" placeholder="Количество" step="any">
                    <button id="placeOrderBtn">📢 РАЗМЕСТИТЬ</button>
                </div>
                <h3>📖 Книга ордеров</h3>
                <div id="orderBook" style="max-height:300px;overflow-y:auto;"></div>
            </div>
        </div>
        <footer>⚡ ЛОКАЛЬНАЯ СИМУЛЯЦИЯ | ДАННЫЕ В localStorage ⚡</footer>
    </div>
</div>

<script>
    (function() {
        // ГЕНЕРАЦИЯ ЗВЁЗД
        function generateStars() {
            const starfield = document.getElementById('starfield');
            if (!starfield) return;
            for (let i = 0; i < 200; i++) {
                const star = document.createElement('div');
                star.classList.add('star');
                star.style.width = (Math.random() * 2 + 1) + 'px';
                star.style.height = star.style.width;
                star.style.left = Math.random() * 100 + '%';
                star.style.top = Math.random() * 100 + '%';
                star.style.animationDuration = (Math.random() * 2 + 1) + 's';
                star.style.animationDelay = (Math.random() * 5) + 's';
                starfield.appendChild(star);
            }
        }
        generateStars();

        // СОСТОЯНИЕ
        let state = { wallets: {}, tokens: {}, orders: {} };
        let currentUser = null;

        function loadData() {
            let raw = localStorage.getItem('NebulaExchange');
            if (!raw) {
                state = { wallets: { system: { balance: { USDT: 1000000000 } } }, tokens: {}, orders: {} };
                saveData();
            } else {
                state = JSON.parse(raw);
            }
        }
        function saveData() { localStorage.setItem('NebulaExchange', JSON.stringify(state)); }
        function ensureWallet(name) {
            if (!state.wallets[name]) { state.wallets[name] = { balance: { USDT: 10000 } }; saveData(); }
        }
        function getBalance(name, asset) { ensureWallet(name); return state.wallets[name].balance[asset] || 0; }
        
        function createToken(creator, name, symbol, supply) {
            symbol = symbol.toUpperCase().trim();
            if (!symbol.match(/^[A-Z0-9]{2,8}$/)) return { error: "Символ 2-8 букв/цифр" };
            if (state.tokens[symbol]) return { error: "Токен существует" };
            if (!Number.isInteger(supply) || supply <= 0) return { error: "Эмиссия >0 целое" };
            ensureWallet(creator);
            state.tokens[symbol] = { name: name.substring(0,30), symbol, totalSupply: supply, creator, createdAt: Date.now() };
            let asset = `TOKEN_${symbol}`;
            if (!state.wallets[creator].balance[asset]) state.wallets[creator].balance[asset] = 0;
            state.wallets[creator].balance[asset] += supply;
            if (!state.orders[symbol]) state.orders[symbol] = [];
            saveData();
            return { success: true, symbol, amount: supply };
        }
        
        function transfer(from, to, asset, amount) {
            if (from === to) return { error: "Себе нельзя" };
            if (amount <= 0) return { error: "Сумма >0" };
            ensureWallet(from); ensureWallet(to);
            if (getBalance(from, asset) < amount) return { error: "Недостаточно" };
            state.wallets[from].balance[asset] -= amount;
            if (!state.wallets[to].balance[asset]) state.wallets[to].balance[asset] = 0;
            state.wallets[to].balance[asset] += amount;
            saveData();
            return { success: true };
        }
        
        function matchOrders(tokenSymbol) {
            let orders = state.orders[tokenSymbol];
            if (!orders || orders.length < 2) return;
            let changed = true;
            let iter = 0;
            while (changed && iter < 50) {
                changed = false;
                iter++;
                let buys = orders.filter(o => o.type === 'buy' && o.amount > 0).sort((a,b) => b.price - a.price);
                let sells = orders.filter(o => o.type === 'sell' && o.amount > 0).sort((a,b) => a.price - b.price);
                for (let buy of buys) {
                    for (let sell of sells) {
                        if (buy.price >= sell.price && buy.amount > 0 && sell.amount > 0) {
                            let trade = Math.min(buy.amount, sell.amount);
                            let price = sell.price;
                            let tokenAsset = `TOKEN_${tokenSymbol}`;
                            ensureWallet(buy.user); ensureWallet(sell.user);
                            if (!state.wallets[buy.user].balance[tokenAsset]) state.wallets[buy.user].balance[tokenAsset] = 0;
                            state.wallets[buy.user].balance[tokenAsset] += trade;
                            state.wallets[sell.user].balance["USDT"] += price * trade;
                            buy.amount -= trade;
                            sell.amount -= trade;
                            changed = true;
                            break;
                        }
                    }
                    if (changed) break;
                }
                orders = orders.filter(o => o.amount > 0);
                state.orders[tokenSymbol] = orders;
            }
            if (changed) saveData();
        }
        
        function placeOrder(user, tokenSymbol, type, price, amount) {
            if (!state.tokens[tokenSymbol]) return { error: "Нет токена" };
            if (price <= 0 || amount <= 0) return { error: "Цена и количество >0" };
            ensureWallet(user);
            let tokenAsset = `TOKEN_${tokenSymbol}`;
            if (type === 'sell') {
                if (getBalance(user, tokenAsset) < amount) return { error: "Мало токенов" };
                state.wallets[user].balance[tokenAsset] -= amount;
            } else {
                let cost = price * amount;
                if (getBalance(user, "USDT") < cost) return { error: `Нужно ${cost.toFixed(2)} USDT` };
                state.wallets[user].balance["USDT"] -= cost;
            }
            let order = { id: Date.now() + Math.random(), user, type, price, amount, tokenSymbol, timestamp: Date.now() };
            if (!state.orders[tokenSymbol]) state.orders[tokenSymbol] = [];
            state.orders[tokenSymbol].push(order);
            saveData();
            matchOrders(tokenSymbol);
            return { success: true };
        }
        
        function matchAll() { for (let s in state.tokens) matchOrders(s); }
        
        function getOrdersForDisplay(sym) {
            let ord = state.orders[sym] || [];
            let buys = ord.filter(o => o.type === 'buy').sort((a,b) => b.price - a.price).slice(0,10);
            let sells = ord.filter(o => o.type === 'sell').sort((a,b) => a.price - b.price).slice(0,10);
            return { buys, sells };
        }
        
        // UI
        function updateUI() {
            if (!currentUser) return;
            ensureWallet(currentUser);
            let balList = document.getElementById('balanceList');
            if (balList) {
                balList.innerHTML = '';
                let b = state.wallets[currentUser].balance;
                for (let a in b) {
                    let li = document.createElement('li');
                    li.innerHTML = `<strong>${a}</strong> : ${b[a].toFixed(6)}`;
                    balList.appendChild(li);
                }
            }
            let tokenDiv = document.getElementById('tokenList');
            if (tokenDiv) {
                tokenDiv.innerHTML = '';
                for (let s in state.tokens) {
                    let t = state.tokens[s];
                    let div = document.createElement('div');
                    div.style.background = '#0f131a'; div.style.margin = '6px 0'; div.style.padding = '8px'; div.style.borderRadius = '8px'; div.style.borderLeft = '3px solid #00ffaa';
                    div.innerHTML = `<b>${t.name}</b> <span class="token-badge">${t.symbol}</span><br>📦 ${t.totalSupply}<br>👤 ${t.creator}`;
                    tokenDiv.appendChild(div);
                }
            }
            let sel = document.getElementById('tradeSymbolSelect');
            if (sel) {
                let old = sel.value;
                sel.innerHTML = '';
                for (let s in state.tokens) {
                    let opt = document.createElement('option');
                    opt.value = s;
                    opt.textContent = `${state.tokens[s].name} (${s})`;
                    sel.appendChild(opt);
                }
                if (old && state.tokens[old]) sel.value = old;
                updateOrderBook();
            }
            let timeSpan = document.getElementById('systemTime');
            if (timeSpan) timeSpan.innerText = new Date().toLocaleTimeString();
        }
        
        function updateOrderBook() {
            let sel = document.getElementById('tradeSymbolSelect');
            if (!sel) return;
            let sym = sel.value;
            if (!sym || !state.tokens[sym]) { document.getElementById('orderBook').innerHTML = '<div>Выберите токен</div>'; return; }
            let { buys, sells } = getOrdersForDisplay(sym);
            let book = document.getElementById('orderBook');
            book.innerHTML = '<div class="order-book-header">🔴 ПРОДАВЦЫ</div>';
            if (sells.length === 0) book.innerHTML += '<div>— нет —</div>';
            sells.forEach(o => { book.innerHTML += `<div class="order-book-entry sell"><span>${o.amount.toFixed(4)}</span><span>${o.price.toFixed(6)} USDT</span><span>${o.user}</span></div>`; });
            book.innerHTML += '<div class="order-book-header">🟢 ПОКУПАТЕЛИ</div>';
            if (buys.length === 0) book.innerHTML += '<div>— нет —</div>';
            buys.forEach(o => { book.innerHTML += `<div class="order-book-entry buy"><span>${o.amount.toFixed(4)}</span><span>${o.price.toFixed(6)} USDT</span><span>${o.user}</span></div>`; });
        }
        
        function showExchange(username) {
            currentUser = username;
            ensureWallet(currentUser);
            localStorage.setItem('NebulaCurrentUser', currentUser);
            document.getElementById('loginScreen').classList.add('hidden');
            document.getElementById('exchangeInterface').classList.add('active');
            updateUI();
            if (!window.matchInterval) window.matchInterval = setInterval(() => { if (currentUser) { matchAll(); updateUI(); } }, 3000);
        }
        
        // ЗАПУСК
        loadData();
        let saved = localStorage.getItem('NebulaCurrentUser');
        if (saved && state.wallets[saved]) {
            showExchange(saved);
        }
        
        // ОБРАБОТЧИКИ (через onload гарантия)
        window.addEventListener('DOMContentLoaded', function() {
            let enterBtn = document.getElementById('enterBtn');
            if (enterBtn) {
                enterBtn.onclick = function() {
                    let name = document.getElementById('loginUsername').value.trim();
                    if (!name) { alert("Введите имя!"); return; }
                    showExchange(name);
                };
            }
            let usernameInput = document.getElementById('loginUsername');
            if (usernameInput) {
                usernameInput.onkeypress = function(e) { if (e.key === 'Enter') document.getElementById('enterBtn').click(); };
            }
            
            let createBtn = document.getElementById('createTokenBtn');
            if (createBtn) {
                createBtn.onclick = function() {
                    if (!currentUser) return;
                    let name = document.getElementById('tokenName').value.trim();
                    let sym = document.getElementById('tokenSymbol').value.trim();
                    let supply = parseInt(document.getElementById('tokenSupply').value);
                    if (!name || !sym || isNaN(supply)) { alert("Заполните все поля"); return; }
                    let res = createToken(currentUser, name, sym, supply);
                    if (res.error) alert(res.error);
                    else { alert(`Токен ${res.symbol} создан!`); document.getElementById('tokenName').value = ''; document.getElementById('tokenSymbol').value = ''; document.getElementById('tokenSupply').value = ''; updateUI(); }
                };
            }
            
            let orderBtn = document.getElementById('placeOrderBtn');
            if (orderBtn) {
                orderBtn.onclick = function() {
                    if (!currentUser) return;
                    let sym = document.getElementById('tradeSymbolSelect').value;
                    if (!state.tokens[sym]) { alert("Выберите токен"); return; }
                    let type = document.getElementById('orderType').value;
                    let price = parseFloat(document.getElementById('orderPrice').value);
                    let amount = parseFloat(document.getElementById('orderAmount').value);
                    if (isNaN(price) || isNaN(amount)) { alert("Введите цену и количество"); return; }
                    let res = placeOrder(currentUser, sym, type, price, amount);
                    if (res.error) alert(res.error);
                    else { updateUI(); document.getElementById('orderPrice').value = ''; document.getElementById('orderAmount').value = ''; }
                };
            }
            
            let transferBtn = document.getElementById('transferBtn');
            if (transferBtn) {
                transferBtn.onclick = function() {
                    if (!currentUser) return;
                    let to = document.getElementById('transferTo').value.trim();
                    let asset = document.getElementById('transferSymbol').value.trim();
                    let amt = parseFloat(document.getElementById('transferAmount').value);
                    if (!to || !asset || isNaN(amt)) { alert("Заполните перевод"); return; }
                    let res = transfer(currentUser, to, asset, amt);
                    if (res.error) alert(res.error);
                    else { updateUI(); document.getElementById('transferAmount').value = ''; }
                };
            }
            
            let tradeSelect = document.getElementById('tradeSymbolSelect');
            if (tradeSelect) tradeSelect.onchange = updateOrderBook;
        });
    })();
</script>
</body>
</html>
